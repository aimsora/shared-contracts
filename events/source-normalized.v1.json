{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source.normalized.v1",
  "title": "SourceNormalizedEventV1",
  "type": "object",
  "required": [
    "eventId",
    "runKey",
    "source",
    "payloadVersion",
    "externalId",
    "title",
    "normalizedAt",
    "sourceUrl",
    "rawEvent"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "runKey": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "entityType": { "type": "string", "enum": ["procurement", "registry", "risk_signal", "company_profile", "auction"] },
    "payloadVersion": { "type": "string", "const": "v1" },
    "externalId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "customer": { "type": "string" },
    "supplier": { "type": "string" },
    "supplierInn": { "type": "string" },
    "supplierOgrn": { "type": "string" },
    "organizerName": { "type": "string" },
    "organizerInn": { "type": "string" },
    "messageType": { "type": "string" },
    "shortName": { "type": "string" },
    "kpp": { "type": "string" },
    "amount": { "type": "number" },
    "startPrice": { "type": "number" },
    "currency": { "type": "string" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "deadlineAt": { "type": "string", "format": "date-time" },
    "biddingDate": { "type": "string", "format": "date-time" },
    "eventDate": { "type": "string", "format": "date-time" },
    "registrationDate": { "type": "string", "format": "date-time" },
    "decisionDate": { "type": "string", "format": "date-time" },
    "inclusionDate": { "type": "string", "format": "date-time" },
    "exclusionDate": { "type": "string", "format": "date-time" },
    "normalizedAt": { "type": "string", "format": "date-time" },
    "sourceUrl": { "type": "string", "format": "uri" },
    "status": { "type": "string" },
    "registryStatus": { "type": "string" },
    "bankruptcyStage": { "type": "string" },
    "caseNumber": { "type": "string" },
    "courtName": { "type": "string" },
    "auctionType": { "type": "string" },
    "lotInfo": { "type": "string" },
    "companyStatus": { "type": "string" },
    "address": { "type": "string" },
    "okved": { "type": "string" },
    "liquidationMark": { "type": "boolean" },
    "legalBasis": { "type": "string" },
    "region": { "type": "string" },
    "riskLevel": { "type": "string" },
    "rawRef": { "type": "string" },
    "sourceSpecificData": {
      "type": "object",
      "additionalProperties": true
    },
    "rawEvent": {
      "type": "object",
      "required": ["eventId", "runKey", "collectedAt", "url", "artifacts"],
      "properties": {
        "eventId": { "type": "string", "minLength": 1 },
        "runKey": { "type": "string", "minLength": 1 },
        "collectedAt": { "type": "string", "format": "date-time" },
        "url": { "type": "string", "format": "uri" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "bucket", "objectKey"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "bucket": { "type": "string", "minLength": 1 },
              "objectKey": { "type": "string", "minLength": 1 },
              "mimeType": { "type": "string" },
              "checksum": { "type": "string" },
              "sizeBytes": { "type": "integer", "minimum": 0 },
              "metadata": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
